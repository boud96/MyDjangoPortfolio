# Copy this file to .env in the repository root.

# Core Django settings
SECRET_KEY=change-for-local-development
DJANGO_DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=

# Local development database. Production should use a real DATABASE_URL.
DATABASE_URL=sqlite:///db.sqlite3

# Local media/static defaults
STATIC_URL=/static/
MEDIA_URL=/media/

# AWS S3 storage is opt-in. Set USE_S3=True in environments that should use S3.
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_CUSTOM_DOMAIN=
AWS_LOCATION=static

# HTTPS/security settings. Production normally sets these to True after HTTPS works.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SECURE_REFERRER_POLICY=same-origin
USE_X_FORWARDED_PROTO=False
